# Beyond Papers configuration (all optional — defaults work out of the box)

# Express listen port
PORT=3000

# SQLite database file location (default: data/beyond.db)
# DB_PATH=data/beyond.db

# AI provider: 'heuristic' (default — deterministic, zero cost, no key needed)
# or 'anthropic' (real AI suggestions/summaries; requires ANTHROPIC_API_KEY)
AI_PROVIDER=heuristic
# ANTHROPIC_API_KEY=sk-ant-...

# Session lifetime in days
SESSION_TTL_DAYS=30

# Master key for encrypting per-user AI API keys at rest (AES-256-GCM).
# 64 hex characters (32 bytes). Generate with: openssl rand -hex 32
# If unset, the bring-your-own-key feature is disabled (routes return 503); the rest of
# the app is unaffected. On Fly.io: fly secrets set CREDENTIAL_ENC_KEY=<64 hex chars>
# CREDENTIAL_ENC_KEY=
