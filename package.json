{
  "name": "beyond-papers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A living, graph-structured platform for research — composite paper-nodes, typed edges, license-tiered ingestion, bounded AI, open creditable review.",
  "scripts": {
    "dev": "tsx watch server/src/index.ts",
    "dev:client": "npm run dev --prefix client",
    "start": "cross-env NODE_ENV=production tsx server/src/index.ts",
    "build": "npm run build --prefix client",
    "check": "tsc --noEmit && npm run check --prefix client",
    "seed": "tsx scripts/seed.ts",
    "test:api": "tsx scripts/apitest.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "cross-env": "^7.0.3",
    "express": "^4.21.2",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
